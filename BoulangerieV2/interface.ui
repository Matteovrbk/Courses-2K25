       <layout class="QVBoxLayout" name="verticalLayout_commandes">
        <item><widget class="QLabel" name="label_produit_cmd"><property name="text"><string>Produit :</string></property></widget></item>
        <item><widget class="QComboBox" name="comboBox_produits"/></item>
        <item><widget class="QLabel" name="label_heure"><property name="text"><string>Heure de départ (HH:MM) :</string></property></widget></item>
