        <item><widget class="QPushButton" name="pushButton_calculer"><property name="text"><string>Calculer le coût</string></property></widget></item>
        <item><widget class="QLabel" name="label_resultat"><property name="text"><string>Coût : -</string></property></widget></item>
        <item>
         <widget class="QTableWidget" name="tableWidget_commandes">
          <column><property name="text"><string>ID</string></property></column>
          <column><property name="text"><string>Date</string></property></column>
          <column><property name="text"><string>Produit</string></property></column>
          <column><property name="text"><string>Heure début</string></property></column>
          <column><property name="text"><string>Heure fin</string></property></column>
          <column><property name="text"><string>Coût (€)</string></property></column>
         </widget>
        </item>
       </layout>
